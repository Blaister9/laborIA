# ─────────────────────────────────────────────────────────────────────────────
# LaborIA — Variables de entorno de PRODUCCIÓN
#
# Copia este archivo al VPS como /etc/laboria/.env.prod
# y rellena los valores reales. NUNCA subas este archivo con valores reales al repo.
#
# cp .env.production.example /etc/laboria/.env.prod
# chmod 600 /etc/laboria/.env.prod
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR

# ── Modelos (igual que dev, no cambiar) ───────────────────────────────────────
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# ── Qdrant (servicio interno Docker — no cambiar) ─────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_CST=cst_articles

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVER_DENSE_TOP_K=20
RETRIEVER_BM25_TOP_K=20
RERANKER_TOP_K=5

# ── Admin ─────────────────────────────────────────────────────────────────────
# Token para POST /admin/reload-prompts. Dejar vacío para deshabilitar el endpoint.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=REEMPLAZAR_CON_TOKEN_SEGURO

# ── CORS: dominios del frontend ───────────────────────────────────────────────
# Netlify genera una URL como https://laboria.netlify.app
# Si tienes dominio propio: https://laboria.app
API_CORS_ORIGINS=["https://laboria.netlify.app","https://laboria.app"]

# ── Corpus (bakeado en imagen Docker — no cambiar) ────────────────────────────
CHUNKS_PATH=/app/corpus/parsed/chunks.json
